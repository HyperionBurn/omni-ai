{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sessionId", "userId", "role", "content", "createdAt"]
    },
    "Artifact": {
      "title": "Artifact",
      "description": "A generated artifact (image, map, report)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "map", "report", "search_results"] },
        "title": { "type": "string" },
        "data": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sessionId", "userId", "type", "title", "data", "createdAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A saved memory or note",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "embedding": { "type": "array", "items": { "type": "number" } },
        "linkedMemories": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Chat sessions owned by users"
    },
    "sessions/{sessionId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a chat session"
    },
    "artifacts/{artifactId}": {
      "schema": { "$ref": "#/entities/Artifact" },
      "description": "Generated artifacts owned by users"
    },
    "memories/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "Saved memories owned by users"
    }
  }
}
