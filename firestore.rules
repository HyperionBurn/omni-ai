rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Domain Validators
    function isValidUser() {
      return hasRequiredFields(['uid', 'email', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.email is string &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidSession() {
      return hasRequiredFields(['id', 'userId', 'title', 'createdAt', 'updatedAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('title', 1, 200) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidMessage(sessionId) {
      return hasRequiredFields(['id', 'sessionId', 'userId', 'role', 'content', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.sessionId == sessionId &&
             request.resource.data.role in ['user', 'model', 'system'] &&
             request.resource.data.content is string &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidArtifact() {
      return hasRequiredFields(['id', 'sessionId', 'userId', 'type', 'title', 'data', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.type in ['image', 'map', 'report', 'search_results'] &&
             isValidString('title', 1, 200) &&
             request.resource.data.data is string &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidMemory() {
      return hasRequiredFields(['userId', 'content', 'createdAt', 'updatedAt']) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.content is string &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser() && request.resource.data.uid == resource.data.uid && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSession();
      allow update: if isDocOwner() && isValidSession() && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid && isValidMessage(sessionId);
        allow update: if false; // Messages are immutable
        allow delete: if false;
      }
    }

    match /artifacts/{artifactId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidArtifact();
      allow update: if isDocOwner() && isValidArtifact() && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /memories/{memoryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMemory();
      allow update: if isDocOwner() && isValidMemory() && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
